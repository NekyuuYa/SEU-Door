<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_settings"
            android:tint="@color/color_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="@string/dlg_cfg"
            android:textColor="@color/color_on_surface"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/cfg_hnt"
        android:textColor="@color/color_on_surface_variant"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/fld_phn"
        android:textColor="@color/color_on_surface"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/phone_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:inputType="phone"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="@color/color_on_surface"
        android:textColorHint="@color/color_on_surface_variant"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/fld_pwd"
        android:textColor="@color/color_on_surface"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/password_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="@color/color_on_surface"
        android:textColorHint="@color/color_on_surface_variant"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/captcha_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/fld_captcha"
            android:textColor="@color/color_on_surface"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <WebView
                android:id="@+id/captcha_webview"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edit_text" />

            <Button
                android:id="@+id/captcha_refresh_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_secondary_button"
                android:fontFamily="sans-serif-medium"
                android:minWidth="92dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="@string/btn_captcha_refresh"
                android:textAllCaps="false"
                android:textColor="@color/color_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/captcha_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_edit_text"
            android:inputType="textVisiblePassword"
            android:maxLength="8"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:textColor="@color/color_on_surface"
            android:textColorHint="@color/color_on_surface_variant"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/error_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/color_error"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_secondary_button"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/color_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/sync_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:stateListAnimator="@null"
            android:text="@string/btn_syn"
            android:textAllCaps="false"
            android:textColor="@color/button_primary_text"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/oauth_or"
        android:textColor="@color/color_on_surface_variant"
        android:textSize="12sp" />

    <Button
        android:id="@+id/alipay_login_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_secondary_button"
        android:fontFamily="sans-serif-medium"
        android:text="@string/btn_alipay"
        android:textAllCaps="false"
        android:textColor="@color/color_primary"
        android:textSize="14sp" />

</LinearLayout>
