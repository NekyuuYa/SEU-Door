<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface"
    android:orientation="vertical">

    <!-- Top app bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/top_title"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical"
            android:text="@string/app_name"
            android:textColor="@color/color_on_surface"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/refresh_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_top_action_button"
                android:contentDescription="@string/act_rfs"
                android:padding="10dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/color_on_surface_variant" />

            <ImageButton
                android:id="@+id/settings_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_top_action_button"
                android:contentDescription="@string/act_set"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/color_on_surface_variant" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="2dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="30dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:id="@+id/status_icon_container"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_status_icon">

                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_lock_outline"
                    android:tint="@color/color_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/status_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineSpacingMultiplier="1.05"
                android:textColor="@color/color_on_surface"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/status_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_status_detail"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:minHeight="160dp"
                android:padding="18dp"
                android:textColor="@color/color_on_surface_variant"
                android:textIsSelectable="true"
                android:textSize="13sp" />

            <Button
                android:id="@+id/ble_open_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_primary_button"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="@string/btn_ble"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text"
                android:textSize="16sp" />

            <Button
                android:id="@+id/ble_fob_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_primary_button"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="@string/btn_fob"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <!-- M3 segmented button (bottom): NFC | Bluetooth mode switch -->
    <FrameLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_segment_container">

        <View
            android:id="@+id/tab_indicator"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_segment_indicator" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tab_nfc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/tab_nfc_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_nfc" />

                <TextView
                    android:id="@+id/tab_nfc_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:text="@string/tab_nfc"
                    android:textColor="@color/color_on_secondary_container"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_ble"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/tab_ble_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bluetooth" />

                <TextView
                    android:id="@+id/tab_ble_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:text="@string/tab_ble"
                    android:textColor="@color/color_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
