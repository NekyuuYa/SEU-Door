<?xml version="1.0" encoding="utf-8"?>
<!-- M3 filled text field: tonal fill, rounded corners, outline thickens/colors on focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/color_surface_input" />
            <stroke android:width="2dp" android:color="@color/color_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/color_surface_input" />
            <stroke android:width="1dp" android:color="@color/color_outline" />
        </shape>
    </item>
</selector>
